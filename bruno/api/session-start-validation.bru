meta {
  name: Session Start - Validation Error (missing pair)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/session/start
  body: json
}

body:json {
  {
    "command": "simulate",
    "interval": "1m"
  }
}

tests {
  test("returns 400 when pair is missing", function() {
    expect(res.status).to.equal(400)
  })

  test("error message is present", function() {
    expect(res.body.error).to.be.a("string")
  })
}
