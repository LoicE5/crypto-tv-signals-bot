PORT=3001
WRITE_SCROLL_LIMIT=5
SIMULATE_SCROLL_LIMIT=15
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Exchange (required for `trade` command) ─────────────────────────────────
# Supported: binance (future) | bybit (linear) | okx (swap)
EXCHANGE=binance
EXCHANGE_MARKET_TYPE=future
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Trading parameters ───────────────────────────────────────────────────────
# TRADE_PAIR: TradingView format (BTCUSDT) — converted to BTC/USDT:USDT internally
# TRADE_AMOUNT: USDT collateral per full position (half for BUY/SELL signals)
# TRADE_LEVERAGE: 1 or 2 (max 2 enforced, ISOLATED margin)
# TRADE_DELAY: seconds between TradingView signal checks
# TRADE_MAX_DRAWDOWN: stop trading and neutralize if balance drops this % from start
TRADE_PAIR=BTCUSDT
TRADE_INTERVAL=1m
TRADE_AMOUNT=100
TRADE_DELAY=60
TRADE_LEVERAGE=2
TRADE_MAX_DRAWDOWN=25

# ── Notifications ────────────────────────────────────────────────────────────
# Telegram (primary) — get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook (alternative — no bot setup, just create a webhook in channel settings)
# DISCORD_WEBHOOK_URL=

# ntfy.sh (self-hostable alternative — zero setup, works without an account)
# NTFY_URL=https://ntfy.sh/my-trading-bot-topic

# ── Database ─────────────────────────────────────────────────────────────────
# Option 1: Local SQLite on VPS (recommended — zero latency, no quota)
DB_PATH=./data/bot.db

# Option 2: Supabase (cloud alternative — create 3 tables: signals, trades, errors)
# Required Supabase SQL setup:
#   CREATE TABLE signals (id BIGSERIAL PRIMARY KEY, pair TEXT, interval TEXT, price FLOAT,
#                         signal TEXT, position TEXT, timestamp BIGINT);
#   CREATE TABLE trades  (id TEXT PRIMARY KEY, pair TEXT, side TEXT, contracts FLOAT,
#                         price FLOAT, leverage INT, position_before TEXT, position_after TEXT,
#                         unrealized_pnl FLOAT, timestamp BIGINT, exchange_id TEXT);
#   CREATE TABLE errors  (id BIGSERIAL PRIMARY KEY, type TEXT, message TEXT,
#                         position TEXT, timestamp BIGINT);
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
