{
  "name": "crypto-tv-signals-bot",
  "version": "1.0.0",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:linux-x64": "bun run scripts/build.ts linux-x64 && bun postbuild",
    "build:linux-arm64": "bun run scripts/build.ts linux-arm64 && bun postbuild",
    "build:macos-x64": "bun run scripts/build.ts macos-x64 && bun postbuild",
    "build:macos-arm64": "bun run scripts/build.ts macos-arm64 && bun postbuild",
    "postbuild": "rm -r .*-*.bun-build || true",
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "bun test",
    "install:chrome": "bunx puppeteer browsers install chrome",
    "docker:build": "docker build -f docker/Dockerfile -t loice5/crypto-tv-signals-bot:1.1.0 .",
    "docker:up": "docker compose -f docker/docker-compose.yaml up"
  },
  "dependencies": {
    "ccxt": "^4.4.80",
    "protobufjs": "^8.0.0",
    "puppeteer": "^24.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "yauzl": "^3.2.1"
  }
}
