{
  "name": "crypto-tv-signals-bot",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:linux-x64": "bun run scripts/build.ts linux-x64 && bun postbuild",
    "build:linux-arm64": "bun run scripts/build.ts linux-arm64 && bun postbuild",
    "build:macos-x64": "bun run scripts/build.ts macos-x64 && bun postbuild",
    "build:macos-arm64": "bun run scripts/build.ts macos-arm64 && bun postbuild",
    "postbuild": "rm -r .*-*.bun-build || true",
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "analyze": "bun run start analyze",
    "simulate": "bun run start simulate",
    "write": "bun run start write",
    "lint": "eslint src/**/*.ts",
    "format": "eslint --fix src/**/*.ts",
    "test": "bun test",
    "install:chrome": "bunx puppeteer browsers install chrome",
    "server": "bun src/server.ts",
    "server:dev": "bun --watch src/server.ts",
    "test:all": "bun test test/",
    "bruno": "cd bruno && bru run api --env local",
    "docker:build": "docker build -f docker/Dockerfile -t loice5/crypto-tv-signals-bot:latest .",
    "docker:up": "docker compose -f docker/docker-compose.yaml run --rm bot",
    "compose": "bun run docker:up",
    "setup:env": "cp .env.example .env",
    "web": "bun run web:dev",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:start": "cd web && bun run start"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "ccxt": "^4.4.80",
    "log-update": "^7.2.0",
    "protobufjs": "^8.0.0",
    "puppeteer": "^24.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@usebruno/cli": "^3.2.0",
    "eslint": "^10.1.0",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "yauzl": "^3.2.1",
    "flatted": "^3.4.2"
  }
}
